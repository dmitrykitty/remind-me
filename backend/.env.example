# RemindMe Backend Configuration
# Copy to .env and adjust as needed

# Debug mode
DEBUG=true

# Face recognition
FACE_MODEL=Facenet512
FACE_DETECTOR=opencv
FACE_DISTANCE_THRESHOLD=0.35

# Object recognition (CLIP)
CLIP_MODEL=clip-ViT-B-32
OBJECT_DISTANCE_THRESHOLD=0.25

# Gemini API (voice commands)
GEMINI_API_KEY=KEY

# Google Cloud / Vertex AI (alternative to API key)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# Fishjam Cloud (AI voice agent rooms)
# Register at https://fishjam.io/app to get these
FISHJAM_ID=
FISHJAM_MANAGEMENT_TOKEN=

# CORS origins (comma-separated in env, but set via list default in config)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
